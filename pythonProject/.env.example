## Локальная конфигурация (НЕ коммитить .env)
#
# Скопируйте этот файл как .env и заполните значения.
#

# --- API стенд / авторизация (обязательно для тестов) ---
BASE_SERVER_URL=
ADMIN_USERNAME=
ADMIN_PASSWORD=

# --- Test IT (TestIT) / TMS (опционально, только если запускаете с --testit) ---
TMS_URL=https://testit.zyfra.com
TMS_PRIVATE_TOKEN=
# ВАЖНО: адаптер ожидает GUID проекта (не число из URL)
TMS_PROJECT_ID=
TMS_CONFIGURATION_ID=ce89a13c-0062-48bd-85c7-e051dfd72fe3

# Рекомендуемый режим: 2 (создавать новый тест-ран на каждый запуск)
TMS_ADAPTER_MODE=2

# (опционально) имя тест-рана
# TMS_TEST_RUN_NAME=Pytest API run

# (опционально) авто-создание тест-кейсов (осторожно: может засорить проект)
# TMS_AUTOMATIC_CREATION_TEST_CASES=false
